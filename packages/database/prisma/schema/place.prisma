model Place {
  id              String                @id @default(uuid())
  name            String
  path            String                @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  groupPermissions GroupPlacePermission[] @relation("GroupPerms")
  userPermissions  UserPlacePermission[] @relation("UserPerms")
  share           Share?
}

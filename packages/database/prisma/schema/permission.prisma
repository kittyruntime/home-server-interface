model GroupPlacePermission {
  id        String  @id @default(uuid())
  groupId   String
  placeId   String
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)
  canShare  Boolean @default(false)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  place Place @relation("GroupPerms", fields: [placeId], references: [id], onDelete: Cascade)
  @@unique([groupId, placeId])
}

model UserPlacePermission {
  id        String  @id @default(uuid())
  userId    String
  placeId   String
  canRead   Boolean @default(false)
  canWrite  Boolean @default(false)
  canDelete Boolean @default(false)
  canShare  Boolean @default(false)
  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  place Place @relation("UserPerms", fields: [placeId], references: [id], onDelete: Cascade)
  @@unique([userId, placeId])
}

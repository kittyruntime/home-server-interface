{
  "id": "vaultwarden",
  "name": "Vaultwarden",
  "category": "Productivity",
  "tagline": "Lightweight, self-hosted password manager (Bitwarden-compatible).",
  "description": "Vaultwarden is an unofficial Bitwarden server implementation in Rust — your passwords stay on your NAS.",
  "website": "https://github.com/dani-garcia/vaultwarden",
  "image": "vaultwarden/server:1.32.1",
  "webUiPort": 80,
  "ports": [{ "container": 80, "protocol": "tcp", "label": "Web UI", "hostDefault": 8081 }],
  "env": [{ "key": "ADMIN_TOKEN", "prompt": "Admin token", "secret": true }],
  "volumes": [{ "target": "/data", "label": "Data", "suggest": "place" }]
}
